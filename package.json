{
	"name": "box-packer",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "vue-tsc -b && vite build",
		"preview": "vite preview",
		"typecheck": "vue-tsc -b --noEmit",
		"format": "prettier --write .",
		"deploy": "pnpm build && gh-pages -d dist"
	},
	"dependencies": {
		"dexie": "^4.4.4",
		"pinia": "^3.0.4",
		"vue": "^3.5.39",
		"vue-router": "^5.1.0",
		"workbox-window": "^7.4.1"
	},
	"devDependencies": {
		"@tailwindcss/vite": "^4.3.1",
		"@types/node": "^26.0.1",
		"@vitejs/plugin-vue": "^6.0.7",
		"gh-pages": "^6.3.0",
		"prettier": "^3.8.4",
		"tailwindcss": "^4.3.1",
		"typescript": "^6.0.3",
		"vite": "^8.1.0",
		"vite-plugin-pwa": "^1.3.0",
		"vue-tsc": "^3.3.5"
	},
	"trustedDependencies": [
		"esbuild",
		"@tailwindcss/oxide"
	]
